# TermuxClawAgent — Environment Variables
# Copy this file to .env and fill in your credentials.
# .env is listed in .gitignore and will NOT be committed.
#
# Usage:
#   cp .env.example .env
#   nano .env   # fill in your keys
#   node telegram-agent-bridge.mjs   # reads .env automatically

# ── Required for Telegram bridge ─────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here
NVIDIA_API_KEY=nvapi-your_nvidia_nim_key_here

# ── Model selection (Telegram bridge) ────────────────────────────────────────
# Default: meta/llama-3.3-70b-instruct (verified working on NIM)
# Confirmed by /diag?ping= on 2026-05-14 — Kimi K2.6 currently hangs.
# Alternatives via NVIDIA NIM (verify with /diag?ping=<name> first):
#   meta/llama-3.1-70b-instruct
#   z-ai/glm-5.1                              (requires NVIDIA_KEY_GLM)
#   qwen/qwen3.5-397b-a17b                    (requires NVIDIA_KEY_QWEN)
MODEL=meta/llama-3.3-70b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_TIMEOUT_MS=300000

# ── Agent tuning ─────────────────────────────────────────────────────────────
MAX_TOOL_ROUNDS=20
HISTORY_MAX_MSGS=60
VAULT_PATH=/storage/emulated/0/Documents/SoligAgentMemory

# ── Provider API keys (used by the TypeScript runtime / CLI) ─────────────────
# ── GitHub two-way storage sync ───────────────────────────────────────────────
# Enables session + vault sync between local Termux and Vercel cloud agent.
# Create a fine-grained token with repo read/write on solis-agent-files.
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_STORAGE_REPO=Everaldtah/solis-agent-files
GITHUB_STORAGE_BRANCH=main

# ── Ubuntu sandbox for ubuntu_exec tool ──────────────────────────────────────
# Powers `ubuntu_exec` so the agent can apt-install and run full-Ubuntu jobs.
# Pick ONE provider:
#
#   E2B (recommended — pay-per-second, ~$0.000014/sec, free credits):
#     UBUNTU_SANDBOX_PROVIDER=e2b
#     E2B_API_KEY=e2b_your_key_here       # https://e2b.dev/dashboard
#
#   Self-hosted HTTP bridge (Modal, Fly Machines, your own VPS, ngrok, etc.):
#     UBUNTU_SANDBOX_PROVIDER=remote
#     UBUNTU_BRIDGE_URL=https://your-host.example.com
#     UBUNTU_BRIDGE_TOKEN=any-shared-secret
#
# If both are unset, ubuntu_exec returns an actionable error and the agent
# falls back to plain shell_exec on Vercel's Amazon Linux.

# ── Provider API keys (used by the TypeScript runtime / CLI) ─────────────────
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
OPENAI_API_KEY=sk-your_openai_key_here
DEEPSEEK_API_KEY=sk-your_deepseek_key_here
MISTRAL_API_KEY=your_mistral_key_here
XAI_API_KEY=xai-your_xai_key_here
GROQ_API_KEY=gsk_your_groq_key_here
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here
